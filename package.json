{
	"name": "international-days-cs",
	"version": "1.3.0",
	"author": "Roman Ožana <roman@ozana.cz> (https://ozana.cz)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OzzyCzech/international-days-cs.git"
	},
	"license": "MIT",
	"description": "International and national days in Czech language",
	"keywords": [
		"czechia",
		"czech republic",
		"czech language",
		"international days",
		"mezinárodní dny",
		"národní dny"
	],
	"type": "module",
	"exports": {
		"types": "./dist/index.d.ts",
		"default": "./dist/index.js"
	},
	"scripts": {
		"build": "pnpm run convert && pnpm run clean && tsc",
		"convert": "js-yaml data/international-days.yaml > lib/international-days.json",
		"test": "tsc --noEmit && vitest",
		"format": "biome check --write",
		"format:check": "biome check .",
		"lint": "biome lint",
		"clean": "rm -rf dist"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.33.0",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@ozzyczech/tsconfig": "^2.0.0",
		"@types/luxon": "^3.7.1",
		"@types/node": "^25.6.0",
		"js-yaml": "^4.1.1",
		"luxon": "^3.7.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	},
	"pnpm": {
		"overrides": {
			"brace-expansion": "^5.0.5",
			"braces": "^3.0.3",
			"cross-spawn": "^7.0.5",
			"js-yaml": "^4.1.1",
			"lodash": "^4.17.23",
			"micromatch": "^4.0.8",
			"picomatch": "^4.0.4",
			"tmp": "^0.2.4"
		}
	}
}
